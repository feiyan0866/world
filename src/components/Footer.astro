---
// Footer.astro — 全局页脚
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-(--color-surface-800)/50 mt-auto">
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
    <p class="text-sm text-(--color-surface-500)">
      © {currentYear} Liu Linyan. All rights reserved.
    </p>

    <div class="flex items-center gap-6">
      <a href="https://dribbble.com" target="_blank" rel="noopener noreferrer" class="text-sm text-(--color-surface-500) hover:text-(--color-brand-400) transition-colors duration-(--duration-fast)">
        Dribbble
      </a>
      <a href="https://behance.net" target="_blank" rel="noopener noreferrer" class="text-sm text-(--color-surface-500) hover:text-(--color-brand-400) transition-colors duration-(--duration-fast)">
        Behance
      </a>
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-sm text-(--color-surface-500) hover:text-(--color-brand-400) transition-colors duration-(--duration-fast)">
        GitHub
      </a>
    </div>
  </div>
</footer>

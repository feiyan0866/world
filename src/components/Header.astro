---
// Header.astro — 全局导航栏
const navLinks = [
  { label: '作品', href: '/' },
  { label: '博客', href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-(--color-surface-950)/70 border-b border-(--color-surface-800)/50" transition:persist>
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-lg font-(family-name:--font-heading) font-semibold text-(--color-surface-50) tracking-tight hover:text-(--color-brand-400) transition-colors duration-(--duration-fast)">
      LZ<span class="text-(--color-brand-400)">.</span>
    </a>

    <!-- Nav Links -->
    <div class="flex items-center gap-8">
      {navLinks.map(({ label, href }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors duration-(--duration-fast)',
              isActive
                ? 'text-(--color-brand-400)'
                : 'text-(--color-surface-400) hover:text-(--color-surface-100)',
            ]}
          >
            {label}
          </a>
        );
      })}
      <a
        href="feiyanyyds@gmail.com"
        class="text-sm font-medium px-4 py-2 rounded-(--radius-pill) border border-(--color-surface-700) text-(--color-surface-300) hover:text-(--color-brand-400) hover:border-(--color-brand-400)/50 transition-all duration-(--duration-normal)"
      >
        联系我
      </a>
    </div>
  </nav>
</header>

<!-- 占位空间，避免 fixed header 遮挡内容 -->
<div class="h-16"></div>
